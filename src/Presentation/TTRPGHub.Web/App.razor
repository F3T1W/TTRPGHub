<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                @if (context.User.Identity?.IsAuthenticated != true)
                {
                    <RedirectToLogin />
                }
                else
                {
                    <p class="text-danger p-4">Нет доступа к этой странице.</p>
                }
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>404 — Не найдено</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <div class="d-flex flex-column align-items-center justify-content-center py-5 text-center">
                <i class="bi bi-map" style="font-size:4rem; color:var(--ta-accent-light);"></i>
                <h2 class="mt-3">Эта страница не существует</h2>
                <p class="text-muted">Возможно, вы свернули не туда в тёмном подземелье.</p>
                <a href="/" class="btn btn-ta-primary mt-3">На главную</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
