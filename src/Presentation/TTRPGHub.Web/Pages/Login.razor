@page "/login"
@using TTRPGHub.Services
@layout EmptyLayout
@inject IApiClient Api
@inject AppAuthStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Войти — Таверна Аферистов</PageTitle>

<div class="ta-auth-wrap">
    <div class="ta-auth-card">

        <div class="text-center mb-4">
            <i class="bi bi-shield-fill-exclamation ta-auth-logo"></i>
            <h2 class="mt-3">Таверна Аферистов</h2>
            <p class="text-muted small">Войдите, чтобы продолжить приключение</p>
        </div>

        <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            @if (_error is not null)
            {
                <div class="alert alert-danger py-2 small" role="alert">
                    <i class="bi bi-exclamation-circle me-1"></i>@_error
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText @bind-Value="_model.Email" class="form-control" placeholder="hero@taverna.ru" type="email" />
                <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
            </div>

            <div class="mb-4">
                <label class="form-label">Пароль</label>
                <InputText @bind-Value="_model.Password" class="form-control" type="password" placeholder="••••••••" />
                <ValidationMessage For="@(() => _model.Password)" class="text-danger small" />
            </div>

            <div class="text-end mb-3">
                <a href="/forgot-password" class="small text-decoration-none" style="color:var(--ta-accent-light);">Забыли пароль?</a>
            </div>

            <button type="submit" class="btn btn-ta-primary w-100" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                Войти
            </button>
        </EditForm>

        <hr class="ta-divider" />

        <p class="text-center text-muted small mb-0">
            Нет аккаунта?
            <a href="/register" class="text-decoration-none" style="color:var(--ta-accent-light);">Зарегистрироваться</a>
        </p>
    </div>
</div>

