@page "/register"
@using TTRPGHub.Services
@layout EmptyLayout
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Регистрация — Таверна Аферистов</PageTitle>

<div class="ta-auth-wrap">
    <div class="ta-auth-card">

        <div class="text-center mb-4">
            <i class="bi bi-person-plus-fill ta-auth-logo"></i>
            <h2 class="mt-3">Создать аккаунт</h2>
            <p class="text-muted small">Присоединяйтесь к таверне авантюристов</p>
        </div>

        @if (_success)
        {
            <div class="alert alert-success text-center">
                <i class="bi bi-check-circle-fill me-2"></i>
                Аккаунт создан! <a href="/login" class="alert-link">Войдите</a>, чтобы начать.
            </div>
        }
        else
        {
            <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                @if (_error is not null)
                {
                    <div class="alert alert-danger py-2 small" role="alert">
                        <i class="bi bi-exclamation-circle me-1"></i>@_error
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Имя пользователя</label>
                    <InputText @bind-Value="_model.Username" class="form-control" placeholder="tavern_master" />
                    <ValidationMessage For="@(() => _model.Username)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="_model.Email" class="form-control" placeholder="hero@taverna.ru" type="email" />
                    <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Пароль</label>
                    <InputText @bind-Value="_model.Password" class="form-control" type="password" placeholder="Минимум 8 символов, A-Z и цифра" />
                    <ValidationMessage For="@(() => _model.Password)" class="text-danger small" />
                </div>

                <button type="submit" class="btn btn-ta-primary w-100" disabled="@_loading">
                    @if (_loading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Зарегистрироваться
                </button>
            </EditForm>
        }

        <hr class="ta-divider" />

        <p class="text-center text-muted small mb-0">
            Уже есть аккаунт?
            <a href="/login" class="text-decoration-none" style="color:var(--ta-accent-light);">Войти</a>
        </p>
    </div>
</div>

