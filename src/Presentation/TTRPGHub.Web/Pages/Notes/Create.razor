@page "/campaigns/{CampaignId:guid}/notes/create"
@attribute [Authorize]
<PageTitle>Новая заметка — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:720px;">
    <h2 class="text-white mb-4">Новая заметка к сессии</h2>

    <div class="ta-card p-4">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label text-white">Заголовок</label>
                <InputText class="form-control" @bind-Value="_model.Title" placeholder="Название сессии или события" />
                <ValidationMessage For="@(() => _model.Title)" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label text-white">Дата сессии</label>
                <InputDate class="form-control" @bind-Value="_model.SessionDate" />
                <ValidationMessage For="@(() => _model.SessionDate)" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label text-white">Заметки</label>
                <InputTextArea class="form-control" @bind-Value="_model.Content"
                               rows="10" placeholder="Что произошло на сессии? NPC, события, решения игроков..." />
                <ValidationMessage For="@(() => _model.Content)" class="text-danger small" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-ta-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Сохранить
                </button>
                <a href="/campaigns/@CampaignId" class="btn btn-outline-light">Отмена</a>
            </div>
        </EditForm>
    </div>
</div>
