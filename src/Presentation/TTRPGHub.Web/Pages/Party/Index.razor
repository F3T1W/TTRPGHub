@page "/party"
@using TTRPGHub.Services
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Найти группу — Таверна Аферистов</PageTitle>

<div class="container-fluid py-2">

    <!-- Заголовок -->
    <div class="mb-4">
        <h2 class="mb-1" style="font-family:'Cinzel',serif;">Найти группу</h2>
        <p class="text-muted small mb-0">Открытые сессии в поиске приключенцев</p>
    </div>

    <!-- Фильтры -->
    <div class="ta-card p-3 mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label small text-muted mb-1">Поиск</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--ta-surface); border-color:var(--ta-border);">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input class="form-control" placeholder="Название сессии..." @bind="_search" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small text-muted mb-1">Система</label>
                <select class="form-select" @bind="_systemFilter">
                    <option value="">Все системы</option>
                    @foreach (var s in _availableSystems)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Места</label>
                <select class="form-select" @bind="_spotsFilter">
                    <option value="0">Любое</option>
                    <option value="1">Есть места</option>
                    <option value="2">2+ мест</option>
                    <option value="3">3+ мест</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex gap-2">
                <button class="btn btn-ta-primary flex-grow-1" @onclick="ApplyFilters">
                    <i class="bi bi-funnel me-1"></i>Найти
                </button>
                <button class="btn btn-outline-secondary" @onclick="ResetFilters" title="Сбросить">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Результаты -->
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color:var(--ta-accent);"></div>
            <p class="text-muted mt-3 small">Ищем приключения...</p>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@_error</div>
    }
    else if (_filtered.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-compass" style="font-size:3rem; opacity:.25;"></i>
            <h5 class="mt-3">Сессии не найдены</h5>
            <p class="small">Попробуй изменить фильтры или
                <a href="/sessions/create" style="color:var(--ta-accent-light);">создай свою сессию</a>
            </p>
        </div>
    }
    else
    {
        <div class="mb-3 small text-muted">
            Найдено: <strong style="color:var(--ta-accent-light);">@_filtered.Count</strong>
            @(_filtered.Count == 1 ? "сессия" : _filtered.Count < 5 ? "сессии" : "сессий")
        </div>

        <div class="row g-3">
            @foreach (var s in _filtered)
            {
                var freeSpots = s.MaxPlayers - s.CurrentPlayers;
                <div class="col-12 col-lg-6 col-xxl-4">
                    <div class="ta-card ta-card-link p-3 h-100 d-flex flex-column lfg-card">
                        <!-- Шапка карточки -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="ta-level-badge">@s.System</span>
                            <span class="badge @(freeSpots > 0 ? "bg-success" : "bg-secondary")">
                                @(freeSpots > 0 ? $"{freeSpots} мест" : "Мест нет")
                            </span>
                        </div>

                        <!-- Название -->
                        <h5 class="mb-1">@s.Title</h5>
                        <p class="text-muted small mb-0">
                            <i class="bi bi-person me-1"></i>@s.OrganizerName
                        </p>

                        <!-- Описание -->
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <p class="small text-muted mt-2 mb-0 lfg-desc">@s.Description</p>
                        }

                        <!-- Метаданные -->
                        <div class="mt-auto pt-3">
                            <div class="d-flex justify-content-between align-items-center small text-muted mb-3">
                                <span><i class="bi bi-calendar3 me-1"></i>@s.ScheduledAt.ToLocalTime().ToString("d MMM, HH:mm")</span>
                                <span>
                                    <i class="bi bi-people me-1"></i>
                                    @s.CurrentPlayers / @s.MaxPlayers
                                    @for (int i = 0; i < s.MaxPlayers; i++)
                                    {
                                        <i class="bi @(i < s.CurrentPlayers ? "bi-person-fill" : "bi-person") ms-1"
                                           style="font-size:.7rem; color:@(i < s.CurrentPlayers ? "var(--ta-accent)" : "var(--ta-text-dim)");"></i>
                                    }
                                </span>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sm flex-shrink-0"
                                        @onclick="@(() => Nav.NavigateTo($"/sessions/{s.Id}"))">
                                    <i class="bi bi-eye me-1"></i>Подробнее
                                </button>
                                @if (freeSpots > 0)
                                {
                                    <button class="btn btn-ta-primary btn-sm flex-grow-1"
                                            @onclick="() => JoinAsync(s.Id)"
                                            disabled="@(_joiningId == s.Id)">
                                        @if (_joiningId == s.Id)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-person-plus me-1"></i>
                                        }
                                        Вступить
                                    </button>
                                }
                            </div>
                            @if (_joinError == s.Id)
                            {
                                <p class="text-danger small mt-1 mb-0">@_joinErrorText</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (_hasMore)
        {
            <div class="text-center mt-4">
                <button class="btn btn-outline-secondary" @onclick="LoadMoreAsync" disabled="@_loadingMore">
                    @if (_loadingMore) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Загрузить ещё
                </button>
            </div>
        }
    }
</div>

