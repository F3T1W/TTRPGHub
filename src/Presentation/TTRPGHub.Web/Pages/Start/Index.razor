@page "/start"
@attribute [Authorize]
<PageTitle>С чего начать — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:900px;">
    <div class="mb-4">
        <h2 class="mb-1">С чего начать</h2>
        <p class="text-muted small">
            Не знаешь с чего начать в настольных ролевых играх? Выбери, кто ты —
            дальше пойдут шаги именно для тебя.
        </p>
    </div>

    <div class="d-flex gap-2 mb-4">
        <button class="btn @(_role == Role.Player ? "btn-ta-primary" : "btn-outline-secondary") flex-grow-1"
                @onclick="() => _role = Role.Player">
            <i class="bi bi-person-fill me-1"></i>Я игрок
        </button>
        <button class="btn @(_role == Role.Gm ? "btn-ta-primary" : "btn-outline-secondary") flex-grow-1"
                @onclick="() => _role = Role.Gm">
            <i class="bi bi-mask me-1"></i>Я мастер
        </button>
    </div>

    <div class="d-flex flex-column gap-3">
        @foreach (var step in _role == Role.Player ? PlayerSteps : GmSteps)
        {
            <div class="ta-card p-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="step-icon">@step.Icon</div>
                    <div class="flex-grow-1">
                        <h5 class="mb-1">@step.Title</h5>
                        <p class="text-muted mb-2">@step.Description</p>
                        @if (step.LinkUrl is not null)
                        {
                            <a href="@step.LinkUrl" class="btn btn-outline-secondary btn-sm">
                                @step.LinkLabel <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .step-icon {
        width: 48px; height: 48px; flex-shrink: 0;
        background: rgba(124,58,237,.15);
        border: 1px solid rgba(124,58,237,.3);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
    }
</style>
