@page "/sessions/create"
@using TTRPGHub.Services
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Создать сессию — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:640px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item">
                <a href="/sessions" class="text-decoration-none" style="color:var(--ta-accent-light);">Сессии</a>
            </li>
            <li class="breadcrumb-item active text-muted">Создать</li>
        </ol>
    </nav>

    <h2 class="mb-4" style="font-family:'Cinzel',serif;">Новая сессия</h2>

    <div class="ta-card p-4">
        <EditForm Model="_form" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Название *</label>
                <InputText class="form-control" @bind-Value="_form.Title" placeholder="Приключение начинается..." />
                <ValidationMessage For="() => _form.Title" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label">Система *</label>
                <InputSelect class="form-select" @bind-Value="_form.System">
                    <option value="">— выберите —</option>
                    @foreach (var s in Systems)
                    {
                        <option value="@s">@s</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => _form.System" class="text-danger small" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label">Максимум игроков *</label>
                    <InputNumber class="form-control" @bind-Value="_form.MaxPlayers" min="2" max="10" />
                    <ValidationMessage For="() => _form.MaxPlayers" class="text-danger small" />
                </div>
                <div class="col-6">
                    <label class="form-label">Дата и время *</label>
                    <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_form.ScheduledAt" />
                    <ValidationMessage For="() => _form.ScheduledAt" class="text-danger small" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Описание</label>
                <InputTextArea class="form-control" rows="4" @bind-Value="_form.Description"
                               placeholder="Что ждёт авантюристов?" />
            </div>

            @if (_error is not null)
            {
                <div class="alert alert-danger py-2 mb-3">
                    <i class="bi bi-exclamation-triangle me-2"></i>@_error
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-ta-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-plus-lg me-1"></i>Создать
                </button>
                <a href="/sessions" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </EditForm>
    </div>
</div>

