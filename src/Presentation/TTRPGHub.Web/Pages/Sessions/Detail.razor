@page "/sessions/{Id:guid}"
@using TTRPGHub.Services
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_session?.Title ?? "Сессия") — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:860px;">
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color:var(--ta-accent);"></div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@_error</div>
    }
    else if (_session is not null)
    {
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item">
                    <a href="/sessions" class="text-decoration-none" style="color:var(--ta-accent-light);">Сессии</a>
                </li>
                <li class="breadcrumb-item active text-muted">@_session.Title</li>
            </ol>
        </nav>

        <!-- Шапка -->
        <div class="ta-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <span class="ta-level-badge me-2">@_session.System</span>
                    <span class="badge @StatusBadgeClass(_session.Status)">@StatusLabel(_session.Status)</span>
                </div>
                <div class="d-flex gap-2">
                    @if (_session.IsCurrentUserParticipant && !_session.IsCurrentUserOrganizer && _session.Status == SessionStatus.Planned)
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="LeaveAsync" disabled="@_actionLoading">
                            <i class="bi bi-box-arrow-left me-1"></i>Покинуть
                        </button>
                    }
                    @if (!_session.IsCurrentUserParticipant && _session.Status == SessionStatus.Planned)
                    {
                        <button class="btn btn-ta-primary btn-sm" @onclick="JoinAsync" disabled="@_actionLoading">
                            @if (_actionLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-person-plus me-1"></i>Вступить
                        </button>
                    }
                    @if (_session.IsCurrentUserOrganizer && _session.Status == SessionStatus.Planned)
                    {
                        <button class="btn btn-success btn-sm" @onclick='() => ChangeStatusAsync(SessionStatus.InProgress)' disabled="@_actionLoading">
                            <i class="bi bi-play-fill me-1"></i>Начать
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick='() => ChangeStatusAsync(SessionStatus.Cancelled)' disabled="@_actionLoading">
                            <i class="bi bi-x-circle me-1"></i>Отменить
                        </button>
                    }
                    @if (_session.IsCurrentUserOrganizer && _session.Status == SessionStatus.InProgress)
                    {
                        <button class="btn btn-secondary btn-sm" @onclick='() => ChangeStatusAsync(SessionStatus.Completed)' disabled="@_actionLoading">
                            <i class="bi bi-check2-circle me-1"></i>Завершить
                        </button>
                    }
                </div>
            </div>

            <h2 class="mb-1" style="font-family:'Cinzel',serif;">@_session.Title</h2>
            <div class="text-muted small mb-3">
                <i class="bi bi-person me-1"></i>Организатор: <strong>@_session.OrganizerName</strong>
            </div>

            @if (!string.IsNullOrEmpty(_session.Description))
            {
                <p class="mb-3">@_session.Description</p>
            }

            <div class="row g-3">
                <div class="col-auto">
                    <div class="stat-chip">
                        <span class="stat-chip-label">Дата</span>
                        <span>@_session.ScheduledAt.ToLocalTime().ToString("d MMMM yyyy, HH:mm")</span>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="stat-chip">
                        <span class="stat-chip-label">Места</span>
                        <span>@_session.Participants.Count / @_session.MaxPlayers</span>
                    </div>
                </div>
            </div>

            @if (_actionError is not null)
            {
                <div class="alert alert-danger py-2 mt-3 mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>@_actionError
                </div>
            }
        </div>

        <!-- Участники -->
        <div class="ta-card p-4">
            <h5 class="text-white mb-3" style="text-transform:uppercase;letter-spacing:.05em;font-size:.8rem;color:var(--ta-accent-light) !important;">
                <i class="bi bi-people me-2"></i>Участники
            </h5>
            <div class="list-group list-group-flush">
                @foreach (var p in _session.Participants.OrderBy(x => x.Role))
                {
                    <div class="list-group-item bg-transparent border-secondary d-flex justify-content-between align-items-center py-2 px-0">
                        <span>
                            <i class="bi @(p.Role == ParticipantRole.DungeonMaster ? "bi-shield-fill" : "bi-person") me-2"
                               style="color:@(p.Role == ParticipantRole.DungeonMaster ? "var(--ta-gold)" : "var(--ta-accent-light)");"></i>
                            @p.Username
                        </span>
                        <span class="badge @(p.Role == ParticipantRole.DungeonMaster ? "bg-warning text-dark" : "bg-primary")">
                            @(p.Role == ParticipantRole.DungeonMaster ? "Мастер" : "Игрок")
                        </span>
                    </div>
                }
            </div>
        </div>
    }
</div>

