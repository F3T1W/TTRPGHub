@page "/sessions"
@using TTRPGHub.Services
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Сессии — Таверна Аферистов</PageTitle>

<div class="container py-4">

    <!-- Заголовок -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0" style="font-family:'Cinzel',serif;">Игровые сессии</h2>
            <p class="text-muted small mb-0">Найди группу или организуй собственную игру</p>
        </div>
        <button class="btn btn-ta-primary" @onclick='() => Nav.NavigateTo("/sessions/create")'>
            <i class="bi bi-plus-lg me-1"></i>Создать сессию
        </button>
    </div>

    <!-- Вкладки -->
    <ul class="nav nav-pills mb-4 gap-2">
        <li class="nav-item">
            <button class="nav-link @(_tab == "upcoming" ? "active" : "")" @onclick='() => SwitchTab("upcoming")'>
                Ближайшие
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_tab == "my" ? "active" : "")" @onclick='() => SwitchTab("my")'>
                Мои сессии
            </button>
        </li>
    </ul>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color:var(--ta-accent);"></div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@_error</div>
    }
    else if (_sessions.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x" style="font-size:3rem;opacity:.3;"></i>
            <p class="mt-3">
                @(_tab == "upcoming"
                    ? "Нет открытых сессий. Создай первую!"
                    : "Вы не участвуете ни в одной сессии.")
            </p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var s in _sessions)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="ta-card ta-card-link p-3 h-100 d-flex flex-column"
                         @onclick="@(() => Nav.NavigateTo($"/sessions/{s.Id}"))">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="ta-level-badge">@s.System</span>
                            <span class="badge @StatusBadgeClass(s.Status)">@StatusLabel(s.Status)</span>
                        </div>
                        <h5 class="mb-1">@s.Title</h5>
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @s.Description
                            </p>
                        }
                        <div class="mt-auto pt-2 border-top border-secondary d-flex justify-content-between small text-muted">
                            <span><i class="bi bi-calendar3 me-1"></i>@s.ScheduledAt.ToLocalTime().ToString("d MMM, HH:mm")</span>
                            <span><i class="bi bi-people me-1"></i>@s.CurrentPlayers / @s.MaxPlayers</span>
                        </div>
                        <div class="small text-muted mt-1">
                            <i class="bi bi-person me-1"></i>@s.OrganizerName
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

