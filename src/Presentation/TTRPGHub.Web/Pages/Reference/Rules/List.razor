@page "/reference/{SystemSlug}/rules/{Category}"
@attribute [Authorize]
<PageTitle>@CategoryLabel(Category) @SystemLabel(SystemSlug) — Таверна Аферистов</PageTitle>

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="/reference" class="text-decoration-none" style="color:var(--ta-accent-light);">Справочник</a></li>
            <li class="breadcrumb-item"><a href="/reference/@SystemSlug/spells" class="text-decoration-none" style="color:var(--ta-accent-light);">@SystemLabel(SystemSlug)</a></li>
            <li class="breadcrumb-item active text-muted">@CategoryLabel(Category)</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <h2 class="text-white mb-0">@CategoryIcon(Category) @SystemLabel(SystemSlug) — @CategoryLabel(Category)</h2>
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var cat in OtherCategories)
            {
                <a href="/reference/@SystemSlug/rules/@cat" class="btn btn-outline-secondary btn-sm">@CategoryLabel(cat)</a>
            }
        </div>
        @if (_canManage)
        {
            <a href="/reference/@SystemSlug/rules/@Category/create" class="btn btn-ta-primary btn-sm ms-auto">
                <i class="bi bi-plus-lg me-1"></i>Добавить запись
            </a>
        }
    </div>

    <div class="ta-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-8">
                <label class="form-label small text-muted mb-1">Поиск</label>
                <input class="form-control" placeholder="Название..." @bind="_search" @bind:event="oninput" @onkeydown="OnSearchKeyDown" />
            </div>
            <div class="col-12 col-md-4 d-flex gap-2">
                <button class="btn btn-ta-primary flex-grow-1" @onclick="ApplyFilters">
                    <i class="bi bi-funnel me-1"></i>Найти
                </button>
                <button class="btn btn-outline-secondary" @onclick="ResetFilters" title="Сбросить">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent);"></div></div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@_error</div>
    }
    else if (_result is null || _result.Items.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-search" style="font-size:2.5rem;opacity:.3;"></i>
            <p class="mt-3">Ничего не найдено. Попробуй изменить поиск.</p>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small">Найдено: <strong style="color:var(--ta-accent-light);">@_result.Total</strong></span>
            <span class="text-muted small">Страница @_result.Page из @_result.TotalPages</span>
        </div>

        <div class="row g-3">
            @foreach (var item in _result.Items)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a href="/reference/@SystemSlug/rules/@Category/@item.Slug" class="ta-card ta-card-link d-block text-decoration-none h-100">
                        <h6 class="text-white mb-1">@item.Title</h6>
                        @if (!string.IsNullOrEmpty(item.Summary))
                        {
                            <p class="text-muted small mb-2">@item.Summary</p>
                        }
                        <div class="d-flex gap-1 flex-wrap">
                            @foreach (var tag in item.Tags)
                            {
                                <span class="badge small" style="background:var(--ta-surface);border:1px solid var(--ta-border);color:var(--ta-accent-light);">@tag</span>
                            }
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (_result.TotalPages > 1)
        {
            <div class="d-flex justify-content-center gap-2 mt-4">
                <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(_page <= 1)">← Назад</button>
                <span class="btn btn-outline-secondary btn-sm disabled">@_page / @_result.TotalPages</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(_page >= _result.TotalPages)">Вперёд →</button>
            </div>
        }
    }
</div>
