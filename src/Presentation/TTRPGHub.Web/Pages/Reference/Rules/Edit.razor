@page "/reference/{SystemSlug}/rules/{Category}/create"
@page "/reference/{SystemSlug}/rules/{Category}/{Slug}/edit"
@attribute [Authorize]
<PageTitle>@(IsEditMode ? "Изменить запись" : "Новая запись") — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:720px;">
    <h2 class="mb-1">@(IsEditMode ? "Изменить запись" : "Новая запись")</h2>
    <p class="text-muted small mb-4">Система: <strong>@SystemSlug</strong></p>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent);"></div></div>
    }
    else
    {
        <div class="ta-card p-4">
            <div class="mb-3">
                <label class="form-label small text-muted">Категория</label>
                <select class="form-select" @bind="_category" disabled="@IsEditMode">
                    @foreach (var c in AllCategories)
                    {
                        <option value="@c">@CategoryLabel(c)</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">Название</label>
                <input class="form-control" @bind="_title" maxlength="200" />
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">Краткое описание (для карточки в списке)</label>
                <input class="form-control" @bind="_summary" maxlength="500" />
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">Полное описание (Markdown)</label>
                <textarea class="form-control" rows="8" @bind="_contentMarkdown"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">
                    Характеристики (JSON-объект — например, для монстра: {"hp": 20, "ac": 14})
                </label>
                <textarea class="form-control font-monospace" rows="5" @bind="_statsJson"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">Теги (через запятую)</label>
                <input class="form-control" @bind="_tagsInput" placeholder="хоррор, безумие, ктулху" />
            </div>

            @if (_error is not null)
            {
                <div class="text-danger small mb-2">@_error</div>
            }

            <div class="d-flex gap-2">
                <button class="btn btn-ta-primary" @onclick="SubmitAsync" disabled="@(_submitting || string.IsNullOrWhiteSpace(_title))">
                    @if (_submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @(IsEditMode ? "Сохранить" : "Создать")
                </button>
                <a href="/reference/@SystemSlug/rules/@Category" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </div>
    }
</div>
