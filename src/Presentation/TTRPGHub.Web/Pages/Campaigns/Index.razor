@page "/campaigns"
@attribute [Authorize]
<PageTitle>Кампании — Таверна Аферистов</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white mb-0">Мои кампании</h2>
        <a href="/campaigns/create" class="btn btn-ta-primary">
            <i class="bi bi-plus-lg me-1"></i>Создать кампанию
        </a>
    </div>

    @if (_loading)
    {
        <div class="text-center text-muted py-5">
            <div class="spinner-border" role="status"></div>
        </div>
    }
    else if (_campaigns.Count == 0)
    {
        <div class="ta-card text-center py-5">
            <i class="bi bi-journal-bookmark display-4 text-muted mb-3 d-block"></i>
            <p class="text-muted">У вас пока нет кампаний. Создайте первую!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var c in _campaigns)
            {
                <div class="col">
                    <div class="ta-card ta-card-link p-3 h-100 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="text-white mb-0">@c.Title</h5>
                            <span class="badge @StatusBadge(c.Status)">@StatusLabel(c.Status)</span>
                        </div>
                        <p class="text-muted small mb-3 flex-grow-1">@(c.Description ?? "Описание отсутствует")</p>
                        <div class="d-flex justify-content-between align-items-center text-muted small mb-3">
                            <span><i class="bi bi-dice-5 me-1"></i>@c.System</span>
                            <span><i class="bi bi-people me-1"></i>@c.ParticipantCount участников</span>
                        </div>
                        @if (c.IsOrganizer)
                        {
                            <span class="badge bg-warning text-dark mb-2">Организатор</span>
                        }
                        <a href="/campaigns/@c.Id" class="btn btn-outline-light btn-sm mt-auto">Открыть</a>
                    </div>
                </div>
            }
        </div>
    }
</div>
