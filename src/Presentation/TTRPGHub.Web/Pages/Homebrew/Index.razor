@page "/homebrew"
<PageTitle>Homebrew Hub — Таверна Аферистов</PageTitle>
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-magic fs-3" style="color:var(--ta-accent)"></i>
            <h1 class="h3 mb-0">Homebrew Hub</h1>
        </div>
        <AuthorizeView>
            <Authorized>
                <a href="/homebrew/create" class="btn btn-ta-primary">
                    <i class="bi bi-plus-lg me-1"></i> Создать
                </a>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="row g-2 mb-4">
        <div class="col-md-4">
            <input class="form-control" placeholder="Поиск..." @bind="_query" @bind:event="oninput" @onkeyup="OnSearchKey" />
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="_system" @bind:after="LoadAsync">
                <option value="">Все системы</option>
                <option>D&D 5e</option>
                <option>Pathfinder 2e</option>
                <option>GURPS</option>
                <option>Call of Cthulhu</option>
                <option>Другая</option>
            </select>
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="_typeFilter" @bind:after="LoadAsync">
                <option value="">Все типы</option>
                @foreach (HomebrewType t in Enum.GetValues<HomebrewType>())
                {
                    <option value="@t">@HomebrewTypeLabel(t)</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" @onclick="LoadAsync">Найти</button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent)"></div></div>
    }
    else if (_data is not null)
    {
        @if (_data.Items.Count == 0)
        {
            <div class="text-center text-secondary py-5">Материалов пока нет. Будь первым!</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in _data.Items)
                {
                    <div class="col-md-6 col-lg-4">
                        <a href="/homebrew/@item.Id" class="ta-card-link p-3 d-block text-decoration-none h-100">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge" style="background:var(--ta-accent)">@HomebrewTypeLabel(Enum.Parse<HomebrewType>(item.Type))</span>
                                <span class="text-secondary small">@item.System</span>
                            </div>
                            <h6 class="mb-1" style="color:var(--ta-accent-light)">@item.Title</h6>
                            <p class="text-secondary small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@item.Description</p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="text-secondary small">@item.AuthorUsername</span>
                                <span class="text-secondary small"><i class="bi bi-heart-fill me-1" style="color:var(--ta-accent)"></i>@item.LikeCount</span>
                            </div>
                        </a>
                    </div>
                }
            </div>

            @if (_data.TotalPages > 1)
            {
                <div class="d-flex gap-2 mt-4">
                    @for (int p = 1; p <= _data.TotalPages; p++)
                    {
                        var pg = p;
                        <button class="btn @(_page == pg ? "btn-ta-primary" : "btn-outline-secondary") btn-sm"
                                @onclick="() => GoToPageAsync(pg)">@pg</button>
                    }
                </div>
            }
        }
    }
</div>
