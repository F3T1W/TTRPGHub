@page "/events/{Id:guid}"
<PageTitle>@(_event?.Title ?? "Событие") — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:800px">
    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent)"></div></div>
    }
    else if (_event is null)
    {
        <div class="ta-card p-4 text-center text-muted">Событие не найдено.</div>
    }
    else
    {
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/events">События</a></li>
                <li class="breadcrumb-item active">@_event.Title</li>
            </ol>
        </nav>

        <div class="ta-card p-4 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <span class="badge me-2" style="background:@FormatColor(_event.Format)">@FormatLabel(_event.Format)</span>
                    <span class="badge bg-secondary">@_event.System</span>
                    @if (_event.IsCancelled)
                    {
                        <span class="badge bg-danger ms-2">Отменено</span>
                    }
                </div>
                @if (_isOrganizer && !_event.IsCancelled)
                {
                    <button class="btn btn-sm btn-outline-danger" @onclick="CancelAsync" disabled="@_acting">
                        Отменить событие
                    </button>
                }
            </div>

            <h2 class="text-white mb-2">@_event.Title</h2>

            <div class="d-flex flex-wrap gap-3 mb-3 text-muted small">
                <span><i class="bi bi-calendar3 me-1"></i>@_event.StartsAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                <span><i class="bi bi-people me-1"></i>@_event.Participants.Count / @_event.MaxParticipants мест</span>
                @if (!string.IsNullOrEmpty(_event.Location))
                {
                    <span><i class="bi bi-geo-alt me-1"></i>@_event.Location</span>
                }
                @if (!string.IsNullOrEmpty(_event.OnlineLink))
                {
                    <span><i class="bi bi-link-45deg me-1"></i><a href="@_event.OnlineLink" target="_blank" style="color:var(--ta-accent-light)">Ссылка</a></span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_event.Description))
            {
                <p class="text-white" style="white-space:pre-wrap">@_event.Description</p>
            }

            <div class="mt-3 text-muted small">
                Организатор: <a href="/users/@_event.OrganizerId" style="color:var(--ta-accent-light)">@_event.OrganizerUsername</a>
            </div>
        </div>

        @if (!_event.IsCancelled && _event.StartsAt > DateTime.Now)
        {
            <AuthorizeView>
                <Authorized>
                    @if (!_isOrganizer)
                    {
                        @if (_isParticipant)
                        {
                            <button class="btn btn-outline-secondary mb-3 w-100" @onclick="UnregisterAsync" disabled="@_acting">
                                <i class="bi bi-x-circle me-1"></i>Отменить регистрацию
                            </button>
                        }
                        else if (_event.Participants.Count < _event.MaxParticipants)
                        {
                            <button class="btn btn-ta-primary mb-3 w-100" @onclick="RegisterAsync" disabled="@_acting">
                                <i class="bi bi-check-circle me-1"></i>Записаться
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-3">Все места заняты.</div>
                        }
                    }
                </Authorized>
                <NotAuthorized>
                    <div class="ta-card p-3 mb-3 text-center text-muted small">
                        <a href="/login" style="color:var(--ta-accent-light)">Войдите</a>, чтобы записаться на событие.
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        }

        @if (_statusMessage is not null)
        {
            <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") mb-3">@_statusMessage</div>
        }

        <div class="ta-card p-4">
            <h5 class="text-white mb-3"><i class="bi bi-people me-2" style="color:var(--ta-accent-light)"></i>Участники (@_event.Participants.Count)</h5>
            @if (_event.Participants.Count == 0)
            {
                <p class="text-muted small mb-0">Пока никто не записался.</p>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var p in _event.Participants)
                    {
                        <a href="/users/@p.UserId" class="d-flex align-items-center gap-2 text-decoration-none" style="color:var(--ta-accent-light)">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:32px;height:32px;background:rgba(124,58,237,.2);border:1px solid var(--ta-accent);flex-shrink:0">
                                @if (!string.IsNullOrEmpty(p.AvatarUrl))
                                {
                                    <img src="@p.AvatarUrl" class="rounded-circle" style="width:32px;height:32px;object-fit:cover" />
                                }
                                else
                                {
                                    <i class="bi bi-person-fill" style="font-size:.8rem"></i>
                                }
                            </div>
                            <span class="small">@p.Username</span>
                        </a>
                    }
                </div>
            }
        </div>
    }
</div>
