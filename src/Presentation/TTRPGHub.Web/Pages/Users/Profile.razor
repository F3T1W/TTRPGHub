@page "/users/{Id:guid}"
<PageTitle>@(_profile?.DisplayName ?? _profile?.Username ?? "Профиль") — Таверна Аферистов</PageTitle>

<div class="container py-4" style="max-width:800px;">
    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent);"></div></div>
    }
    else if (_profile is null)
    {
        <div class="ta-card p-4 text-center"><p class="text-muted">Пользователь не найден.</p></div>
    }
    else
    {
        <!-- Шапка профиля -->
        <div class="ta-card p-4 mb-3">
            <div class="d-flex align-items-center gap-4 flex-wrap">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:80px;height:80px;background:rgba(124,58,237,.2);border:2px solid var(--ta-accent);">
                    @if (!string.IsNullOrEmpty(_profile.AvatarUrl))
                    {
                        <img src="@_profile.AvatarUrl" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;" alt="Аватар" />
                    }
                    else
                    {
                        <i class="bi bi-person-fill" style="font-size:2.5rem;color:var(--ta-accent-light);"></i>
                    }
                </div>
                <div class="flex-grow-1">
                    <h2 class="text-white mb-0">@(_profile.DisplayName ?? _profile.Username)</h2>
                    @if (_profile.DisplayName is not null)
                    {
                        <div class="text-muted small">@@@_profile.Username</div>
                    }
                    <div class="d-flex gap-3 mt-2 flex-wrap">
                        <span class="badge ta-level-badge">@_profile.ExperienceLevel</span>
                        @if (!string.IsNullOrEmpty(_profile.City))
                        {
                            <span class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@_profile.City</span>
                        }
                        <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>С @_profile.MemberSince.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_profile.Bio))
            {
                <hr style="border-color:var(--ta-border);" />
                <p class="text-white mb-0" style="white-space:pre-wrap;">@_profile.Bio</p>
            }
        </div>

        <!-- Персонажи -->
        @if (_profile.Characters.Count > 0)
        {
            <div class="ta-card p-4 mb-3">
                <h5 class="text-white mb-3"><i class="bi bi-person-badge me-2" style="color:var(--ta-accent-light);"></i>Персонажи</h5>
                <div class="row g-2">
                    @foreach (var ch in _profile.Characters)
                    {
                        <div class="col-12 col-md-6">
                            <a href="/characters/@ch.Id" class="ta-card ta-card-link p-3 d-block text-decoration-none">
                                <div class="text-white fw-semibold">@ch.Name</div>
                                <div class="text-muted small">@ch.Race · @ch.Class · @ch.Level ур.</div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Кампании -->
        @if (_profile.Campaigns.Count > 0)
        {
            <div class="ta-card p-4">
                <h5 class="text-white mb-3"><i class="bi bi-journal-bookmark me-2" style="color:var(--ta-accent-light);"></i>Кампании</h5>
                <div class="row g-2">
                    @foreach (var c in _profile.Campaigns)
                    {
                        <div class="col-12 col-md-6">
                            <a href="/campaigns/@c.Id" class="ta-card ta-card-link p-3 d-block text-decoration-none">
                                <div class="text-white fw-semibold">@c.Title</div>
                                <div class="text-muted small">@c.System · @c.Status</div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_profile.Characters.Count == 0 && _profile.Campaigns.Count == 0)
        {
            <div class="ta-card p-4 text-center text-muted">
                <i class="bi bi-moon-stars mb-2" style="font-size:2rem;"></i>
                <p class="mb-0">Пока ничего публичного нет.</p>
            </div>
        }
    }
</div>
