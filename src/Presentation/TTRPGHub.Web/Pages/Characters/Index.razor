@page "/characters"
@using TTRPGHub.Services
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Персонажи — Таверна Аферистов</PageTitle>

<div class="mb-4">
    <h2 class="mb-1">Мои персонажи</h2>
    <p class="text-muted small mb-0">Управляй своими героями</p>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border" style="color:var(--ta-accent);" role="status"></div>
        <p class="text-muted mt-3">Загружаем персонажей...</p>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@_error
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadAsync">Повторить</button>
    </div>
}
else if (_characters.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-person-plus" style="font-size:4rem; color:var(--ta-accent-light); opacity:.4;"></i>
        <h5 class="mt-3">Пока нет персонажей</h5>
        <p class="text-muted">Создай своего первого героя и отправляйся в приключение!</p>
        <a href="/characters/create" class="btn btn-ta-primary mt-2">
            <i class="bi bi-plus-lg me-1"></i>Создать персонажа
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var c in _characters)
        {
            <div class="col-sm-6 col-xl-4">
                <a href="/characters/@c.Id" class="ta-card d-flex gap-3 p-4 text-decoration-none align-items-center">
                    <!-- Аватар -->
                    <div class="char-card-avatar flex-shrink-0">
                        @if (!string.IsNullOrEmpty(c.AvatarUrl))
                        {
                            <img src="@c.AvatarUrl" alt="@c.Name" class="char-card-avatar-img" />
                        }
                        else
                        {
                            <div class="char-card-avatar-placeholder">
                                <i class="bi bi-person" style="font-size:1.6rem; color:var(--ta-accent-light); opacity:.4;"></i>
                            </div>
                        }
                    </div>
                    <!-- Инфо -->
                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <h5 class="mb-0 text-truncate" style="font-family:'Cinzel',serif;">@c.Name</h5>
                            <span class="ta-level-badge flex-shrink-0">@c.Level ур.</span>
                        </div>
                        <p class="text-muted small mb-2">@c.Race · @c.Class</p>
                        <p class="text-muted small mb-0">
                            <i class="bi bi-clock me-1"></i>
                            Обновлён @c.UpdatedAt.ToLocalTime().ToString("d MMM yyyy")
                        </p>
                    </div>
                </a>
            </div>
        }
    </div>
}

