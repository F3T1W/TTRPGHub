@page "/characters"
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Персонажи — Таверна Аферистов</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">Мои персонажи</h2>
        <p class="text-muted small mb-0">Управляй своими героями</p>
    </div>
    <a href="/characters/create" class="btn btn-ta-primary">
        <i class="bi bi-plus-lg me-1"></i>Новый персонаж
    </a>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border" style="color:var(--ta-accent);" role="status"></div>
        <p class="text-muted mt-3">Загружаем персонажей...</p>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@_error
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadAsync">Повторить</button>
    </div>
}
else if (_characters.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-person-plus" style="font-size:4rem; color:var(--ta-accent-light); opacity:.4;"></i>
        <h5 class="mt-3">Пока нет персонажей</h5>
        <p class="text-muted">Создай своего первого героя и отправляйся в приключение!</p>
        <a href="/characters/create" class="btn btn-ta-primary mt-2">
            <i class="bi bi-plus-lg me-1"></i>Создать персонажа
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var c in _characters)
        {
            <div class="col-sm-6 col-xl-4">
                <a href="/characters/@c.Id" class="ta-card d-block p-4 text-decoration-none">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <h5 class="mb-1" style="font-family:'Cinzel',serif;">@c.Name</h5>
                            <p class="text-muted small mb-2">@c.Race · @c.Class</p>
                        </div>
                        <span class="ta-level-badge">@c.Level ур.</span>
                    </div>
                    <hr class="ta-divider my-2" />
                    <p class="text-muted small mb-0">
                        <i class="bi bi-clock me-1"></i>
                        Обновлён @c.UpdatedAt.ToLocalTime().ToString("d MMM yyyy")
                    </p>
                </a>
            </div>
        }
    </div>
}

@code {
    private List<CharacterSummaryDto> _characters = [];
    private string? _error;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;

        try
        {
            _characters = await Api.GetMyCharactersAsync();
        }
        catch
        {
            _error = "Не удалось загрузить персонажей.";
        }
        finally
        {
            _loading = false;
        }
    }
}
