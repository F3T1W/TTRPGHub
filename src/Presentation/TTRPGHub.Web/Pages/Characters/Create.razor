@page "/characters/create"
@attribute [Authorize]
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Новый персонаж — Таверна Аферистов</PageTitle>

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/characters" style="color:var(--ta-accent-light);">Персонажи</a></li>
            <li class="breadcrumb-item active">Создать</li>
        </ol>
    </nav>
    <h2 class="mb-1">Новый персонаж</h2>
    <p class="text-muted small">Заполни лист героя</p>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="ta-card p-4">
            <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                @if (_error is not null)
                {
                    <div class="alert alert-danger py-2 small">
                        <i class="bi bi-exclamation-circle me-1"></i>@_error
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Имя персонажа</label>
                    <InputText @bind-Value="_model.Name" class="form-control" placeholder="Аргус Тёмный" />
                    <ValidationMessage For="@(() => _model.Name)" class="text-danger small" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label">Раса</label>
                        <InputSelect @bind-Value="_model.Race" class="form-select">
                            <option value="">— выбери расу —</option>
                            @foreach (var r in _races)
                            {
                                <option value="@r">@r</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.Race)" class="text-danger small" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Класс</label>
                        <InputSelect @bind-Value="_model.Class" class="form-select">
                            <option value="">— выбери класс —</option>
                            @foreach (var c in _classes)
                            {
                                <option value="@c">@c</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.Class)" class="text-danger small" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Начальный уровень: <strong style="color:var(--ta-accent-light);">@_model.Level</strong></label>
                    <InputNumber @bind-Value="_model.Level" class="form-range" type="range" min="1" max="20" />
                    <div class="d-flex justify-content-between text-muted" style="font-size:.75rem;">
                        <span>1</span><span>10</span><span>20</span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-ta-primary flex-grow-1" disabled="@_loading">
                        @if (_loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        Создать персонажа
                    </button>
                    <a href="/characters" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private readonly CharacterModel _model = new();
    private string? _error;
    private bool _loading;

    private static readonly string[] _races =
        ["Человек", "Эльф", "Дварф", "Полурослик", "Гном", "Полуэльф",
         "Полуорк", "Тифлинг", "Драконорождённый", "Другое"];

    private static readonly string[] _classes =
        ["Варвар", "Бард", "Жрец", "Друид", "Воин", "Монах",
         "Паладин", "Следопыт", "Плут", "Чародей", "Колдун", "Волшебник"];

    private async Task SubmitAsync()
    {
        _loading = true;
        _error   = null;

        try
        {
            var result = await Api.CreateCharacterAsync(
                new(_model.Name, _model.Race, _model.Class, _model.Level));
            Nav.NavigateTo($"/characters/{result.CharacterId}");
        }
        catch
        {
            _error = "Не удалось создать персонажа. Попробуй ещё раз.";
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class CharacterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введи имя персонажа.")]
        [System.ComponentModel.DataAnnotations.StringLength(64, ErrorMessage = "Максимум 64 символа.")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Выбери расу.")]
        public string Race { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Выбери класс.")]
        public string Class { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Range(1, 20)]
        public int Level { get; set; } = 1;
    }
}
