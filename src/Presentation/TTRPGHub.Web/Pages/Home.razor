@page "/"

<PageTitle>Таверна Аферистов</PageTitle>

<div class="mb-4">
    <h1 style="font-size:clamp(1.6rem,3vw,2.2rem);">
        Добро пожаловать в Таверну
    </h1>
    <p class="text-muted">Твоё место для TTRPG приключений на русском языке.</p>
</div>  

<AuthorizeView>
    <Authorized>
        <!-- Быстрые действия для авторизованного -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
                <a href="/characters" class="ta-card ta-card-link d-block p-4 text-decoration-none">
                    <i class="bi bi-person-badge" style="font-size:2rem; color:var(--ta-accent-light);"></i>
                    <h6 class="mt-3 mb-1">Персонажи</h6>
                    <p class="text-muted small mb-0">Управляй своими героями</p>
                </a>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="ta-card d-block p-4" style="opacity:.5; cursor:not-allowed;">
                    <i class="bi bi-dice-5" style="font-size:2rem; color:var(--ta-gold);"></i>
                    <h6 class="mt-3 mb-1">Сессии <span class="badge bg-secondary ms-1" style="font-size:.6rem;">Скоро</span></h6>
                    <p class="text-muted small mb-0">Найди игру или веди кампанию</p>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="ta-card d-block p-4" style="opacity:.5; cursor:not-allowed;">
                    <i class="bi bi-journal-bookmark" style="font-size:2rem; color:var(--ta-accent-light);"></i>
                    <h6 class="mt-3 mb-1">Правила <span class="badge bg-secondary ms-1" style="font-size:.6rem;">Скоро</span></h6>
                    <p class="text-muted small mb-0">Справочник по D&D 5e на русском</p>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="ta-card d-block p-4" style="opacity:.5; cursor:not-allowed;">
                    <i class="bi bi-people" style="font-size:2rem; color:var(--ta-gold);"></i>
                    <h6 class="mt-3 mb-1">Группы <span class="badge bg-secondary ms-1" style="font-size:.6rem;">Скоро</span></h6>
                    <p class="text-muted small mb-0">Найди команду для приключений</p>
                </div>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <!-- Hero-секция для гостей -->
        <div class="row align-items-center mb-5" style="min-height:300px;">
            <div class="col-lg-6">
                <p class="lead text-muted mb-4">
                    Первый русскоязычный хаб для настольных ролевых игр.
                    Создавай персонажей, находи группы, изучай правила — всё в одном месте.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/register" class="btn btn-ta-primary btn-lg px-4">
                        <i class="bi bi-person-plus me-2"></i>Начать бесплатно
                    </a>
                    <a href="/login" class="btn btn-outline-secondary btn-lg px-4">
                        Войти
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-flex justify-content-center">
                <i class="bi bi-shield-fill-exclamation" style="font-size:10rem; color:var(--ta-accent); opacity:.15;"></i>
            </div>
        </div>

        <!-- Фичи -->
        <div class="row g-3">
            @foreach (var f in Features)
            {
                <div class="col-sm-6 col-lg-3">
                    <div class="ta-card p-4 h-100">
                        <i class="@f.Icon" style="font-size:1.8rem; color:var(--ta-accent-light);"></i>
                        <h6 class="mt-3 mb-1">@f.Title</h6>
                        <p class="text-muted small mb-0">@f.Description</p>
                    </div>
                </div>
            }
        </div>
    </NotAuthorized>
</AuthorizeView>

