@page "/forum"
<PageTitle>Форум — Таверна Аферистов</PageTitle>
<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <i class="bi bi-chat-square-dots-fill fs-3" style="color: var(--ta-accent)"></i>
        <h1 class="h3 mb-0">Форум</h1>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent)"></div></div>
    }
    else if (_categories is not null)
    {
        foreach (var cat in _categories)
        {
            <div class="ta-card p-3 mb-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <a href="/forum/@cat.Slug" class="fw-semibold fs-5 text-decoration-none" style="color:var(--ta-accent-light)">@cat.Name</a>
                        <p class="text-secondary small mb-0 mt-1">@cat.Description</p>
                    </div>
                    <span class="badge bg-secondary ms-3">@cat.TopicCount тем</span>
                </div>
            </div>
        }
    }
</div>
