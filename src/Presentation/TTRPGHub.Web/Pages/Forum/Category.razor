@page "/forum/{Slug}"
<PageTitle>Форум — Таверна Аферистов</PageTitle>
<div class="container-fluid py-4">
    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border" style="color:var(--ta-accent)"></div></div>
    }
    else if (_data is not null)
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/forum">Форум</a></li>
                        <li class="breadcrumb-item active">@_categoryName</li>
                    </ol>
                </nav>
                <h1 class="h3 mb-0">@_categoryName</h1>
            </div>
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-ta-primary" @onclick="() => _showCreate = true">
                        <i class="bi bi-plus-lg me-1"></i> Новая тема
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>

        @if (_showCreate)
        {
            <div class="ta-card p-3 mb-4">
                <h5>Новая тема</h5>
                <input class="form-control mb-2" placeholder="Заголовок" @bind="_newTitle" />
                <textarea class="form-control mb-2" rows="5" placeholder="Первое сообщение..." @bind="_newContent"></textarea>
                <div class="d-flex gap-2">
                    <button class="btn btn-ta-primary" @onclick="CreateTopicAsync">Создать</button>
                    <button class="btn btn-outline-secondary" @onclick="() => _showCreate = false">Отмена</button>
                </div>
                @if (_createError is not null)
                {
                    <div class="alert alert-danger mt-2 mb-0">@_createError</div>
                }
            </div>
        }

        @foreach (var topic in _data.Items)
        {
            <a href="/forum/topic/@topic.Id" class="ta-card-link p-3 mb-2 d-block text-decoration-none">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        @if (topic.IsPinned)
                        {
                            <i class="bi bi-pin-fill me-1" style="color:var(--ta-gold)"></i>
                        }
                        @if (topic.IsLocked)
                        {
                            <i class="bi bi-lock-fill me-1 text-secondary"></i>
                        }
                        <span class="fw-semibold" style="color:var(--ta-accent-light)">@topic.Title</span>
                        <div class="text-secondary small mt-1">
                            @topic.AuthorUsername · @topic.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                        </div>
                    </div>
                    <div class="text-end text-secondary small ms-3">
                        <div><i class="bi bi-chat me-1"></i>@topic.PostCount</div>
                        @if (topic.LastPostAt.HasValue)
                        {
                            <div>@topic.LastPostAt.Value.ToLocalTime().ToString("dd.MM HH:mm")</div>
                        }
                    </div>
                </div>
            </a>
        }

        @if (_data.TotalPages > 1)
        {
            <div class="d-flex gap-2 mt-3">
                @for (int p = 1; p <= _data.TotalPages; p++)
                {
                    var pg = p;
                    <button class="btn @(_page == pg ? "btn-ta-primary" : "btn-outline-secondary") btn-sm"
                            @onclick="() => LoadPageAsync(pg)">@pg</button>
                }
            </div>
        }
    }
</div>
