@page "/glossary"
@inherits IndexBase

<PageTitle>Словарь терминов — Таверна Аферистов</PageTitle>

<div class="container-fluid px-3 py-3">
    <div class="d-flex align-items-center mb-3 gap-2">
        <i class="bi bi-journal-text fs-4" style="color: var(--ta-accent-light)"></i>
        <h4 class="mb-0" style="color: var(--ta-accent-light)">Словарь терминов</h4>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control form-control-sm bg-dark text-light border-secondary"
                   placeholder="Поиск термина..."
                   @bind="SearchQuery" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select form-select-sm bg-dark text-light border-secondary"
                    @bind="SelectedCategory">
                <option value="">Все категории</option>
                @foreach (var cat in AllCategories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-1 mb-3">
        <button class="btn btn-sm @(SelectedLetter == null ? "btn-ta-primary" : "btn-outline-secondary")"
                @onclick="() => SelectedLetter = null">Все</button>
        @foreach (var letter in AllLetters)
        {
            <button class="btn btn-sm @(SelectedLetter == letter ? "btn-ta-primary" : "btn-outline-secondary")"
                    @onclick="() => SelectedLetter = letter">@letter</button>
        }
    </div>

    @if (!FilteredTerms.Any())
    {
        <div class="text-center text-muted py-5">Термины не найдены</div>
    }
    else
    {
        <div class="row g-2">
            @foreach (var term in FilteredTerms)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="ta-card p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <strong style="color: var(--ta-accent-light)">@term.Name</strong>
                            <span class="badge ms-2" style="background-color: @CategoryColor(term.Category); font-size: 0.7rem">@term.Category</span>
                        </div>
                        @if (!string.IsNullOrEmpty(term.Alt))
                        {
                            <div class="text-muted small mb-1">также: @term.Alt</div>
                        }
                        <div class="small text-light">@term.Description</div>
                    </div>
                </div>
            }
        </div>
    }
</div>
