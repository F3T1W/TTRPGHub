@page "/reset-password"
@attribute [AllowAnonymous]
<PageTitle>Новый пароль — Таверна Аферистов</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="ta-auth-card p-4" style="max-width:420px;width:100%;">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock mb-2" style="font-size:2rem;color:var(--ta-accent-light);display:block;"></i>
            <h3 class="text-white">Новый пароль</h3>
        </div>

        @if (_noToken)
        {
            <div class="alert alert-danger">Некорректная ссылка сброса пароля.</div>
        }
        else if (_success)
        {
            <div class="alert alert-success text-center">
                <i class="bi bi-check-circle me-2"></i>Пароль успешно изменён!
            </div>
            <a href="/login" class="btn btn-ta-primary w-100 mt-2">Войти</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <div class="mb-3">
                <label class="form-label text-muted">Новый пароль</label>
                <input type="password" class="form-control" @bind="_password" placeholder="Минимум 8 символов" />
            </div>
            <div class="mb-3">
                <label class="form-label text-muted">Повторите пароль</label>
                <input type="password" class="form-control" @bind="_confirm" />
            </div>

            <button class="btn btn-ta-primary w-100" @onclick="SubmitAsync" disabled="@_loading">
                @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Сохранить пароль
            </button>
        }
    </div>
</div>
