@page "/confirm-email"
@attribute [AllowAnonymous]
<PageTitle>Подтверждение email — Таверна Аферистов</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="ta-auth-card p-4 text-center" style="max-width:420px;width:100%;">
        <i class="bi bi-envelope-check mb-3" style="font-size:3rem;color:var(--ta-accent-light);"></i>
        <h3 class="text-white mb-3">Подтверждение email</h3>

        @if (_loading)
        {
            <div class="spinner-border" style="color:var(--ta-accent);"></div>
        }
        else if (_success)
        {
            <div class="alert alert-success">Email успешно подтверждён!</div>
            <a href="/login" class="btn btn-ta-primary w-100 mt-2">Войти</a>
        }
        else
        {
            <div class="alert alert-danger">@_error</div>
            <a href="/" class="btn btn-outline-light w-100 mt-2">На главную</a>
        }
    </div>
</div>
