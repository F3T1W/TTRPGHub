@page "/forgot-password"
@attribute [AllowAnonymous]
<PageTitle>Восстановление пароля — Таверна Аферистов</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="ta-auth-card p-4" style="max-width:420px;width:100%;">
        <div class="text-center mb-4">
            <i class="bi bi-key mb-2" style="font-size:2rem;color:var(--ta-accent-light);display:block;"></i>
            <h3 class="text-white">Восстановление пароля</h3>
            <p class="text-muted small">Введите email — мы отправим ссылку для сброса</p>
        </div>

        @if (_sent)
        {
            <div class="alert alert-success text-center">
                <i class="bi bi-check-circle me-2"></i>
                Если аккаунт существует, письмо отправлено.
            </div>
            <a href="/login" class="btn btn-outline-light w-100 mt-2">Вернуться ко входу</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <div class="mb-3">
                <label class="form-label text-muted">Email</label>
                <input type="email" class="form-control" @bind="_email" placeholder="you@example.com" />
            </div>

            <button class="btn btn-ta-primary w-100" @onclick="SendAsync" disabled="@_loading">
                @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Отправить ссылку
            </button>

            <div class="text-center mt-3">
                <a href="/login" style="color:var(--ta-accent-light);" class="small text-decoration-none">← Вернуться ко входу</a>
            </div>
        }
    </div>
</div>
