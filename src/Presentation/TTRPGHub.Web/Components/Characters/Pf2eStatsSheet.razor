@using TTRPGHub.Services

@if (AllowCreate && !_showPf2e)
{
    <button class="btn btn-outline-secondary" @onclick="() => { _showPf2e = true; StartEditPf2e(); }" disabled="@ReadOnly">
        <i class="bi bi-plus-lg me-1"></i>Добавить PF2e-лист
    </button>
}
else if (_showPf2e)
{
    <div class="@(Compact ? "" : "ta-card p-4")">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 class="sheet-section-title mb-0">Лист PF2e · @Character.Name</h6>
            @if (!ReadOnly)
            {
                @if (!_editingPf2e)
                {
                    <button class="btn btn-sm btn-ta-primary" @onclick="StartEditPf2e">
                        <i class="bi bi-pencil me-1"></i>Редактировать
                    </button>
                }
                else
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-success" @onclick="SavePf2eAsync" disabled="@_savingPf2e">
                            @if (_savingPf2e) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Сохранить
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditPf2e">Отмена</button>
                    </div>
                }
            }
        </div>
                    @if (_pf2eSaveError is not null)
                    {
                        <div class="alert alert-danger py-2 mb-3">@_pf2eSaveError</div>
                    }

                    <div class="row g-4">
                        <div class="@ColClass">
                            <h6 class="small text-muted mb-2">Основное</h6>
                            <div class="mb-2">
                                <label class="form-label small text-muted mb-1">Ключевая характеристика</label>
                                @if (_editingPf2e)
                                {
                                    <select class="form-select form-select-sm" value="@_pf2e.KeyAbility"
                                            @onchange='e => _pf2e = _pf2e with { KeyAbility = e.Value?.ToString() ?? "str" }'>
                                        @foreach (var (key, label) in Pf2eAbilities)
                                        {
                                            <option value="@key">@label</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <div>@Pf2eAbilities.First(a => a.Key == _pf2e.KeyAbility).Label</div>
                                }
                            </div>
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="small">Внимательность</span>
                                @if (_editingPf2e)
                                {
                                    <select class="form-select form-select-sm" style="width:auto;" value="@_pf2e.PerceptionRank"
                                            @onchange="e => _pf2e = _pf2e with { PerceptionRank = int.Parse(e.Value!.ToString()!) }">
                                        @foreach (var (val, label) in Pf2eRanks)
                                        {
                                            <option value="@val" disabled="@(Character.Level < Pf2eLookups.MinLevelForRank(val))"
                                                        title="@(Character.Level < Pf2eLookups.MinLevelForRank(val) ? $"Недоступно раньше {Pf2eLookups.MinLevelForRank(val)} уровня" : null)">@label</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <span class="fw-semibold" style="color:var(--ta-accent-light);">
                                        +@(Pf2eBonus(_pf2e.PerceptionRank) + _perceptionBonusFromFeats)
                                        @if (_perceptionBonusFromFeats != 0)
                                        {
                                            <small class="text-success" title="Автоматически из связанных фитов (J.1)">(@Pf2eBonus(_pf2e.PerceptionRank)+@_perceptionBonusFromFeats)</small>
                                        }
                                    </span>
                                }
                            </div>
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="small" title="10 + мод. Ловкости (ограничен Dex Cap брони) + владение категорией брони + бонус доспеха/щита. Не учитывает вариативные правила стола (ABP) — это расчёт вне сессии.">КЗ (расчёт)</span>
                                <span class="fw-semibold" style="color:var(--ta-accent-light);">@_computedArmorClass</span>
                            </div>
                            @if (_editingPf2e)
                            {
                                <div class="mb-2">
                                    <label class="form-label small text-muted mb-1">Владение бронёй</label>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var (catKey, catLabel) in ArmorCategories)
                                        {
                                            <div class="d-flex align-items-center gap-1">
                                                <span class="small text-muted">@catLabel</span>
                                                <select class="form-select form-select-sm" style="width:auto;"
                                                        value="@_pf2e.ArmorProficiencyRanks.GetValueOrDefault(catKey)"
                                                        @onchange="e => UpdateArmorProficiencyRank(catKey, int.Parse(e.Value!.ToString()!))">
                                                    @foreach (var (val, label) in Pf2eRanks)
                                                    {
                                                        <option value="@val" disabled="@(Character.Level < Pf2eLookups.MinLevelForRank(val))"
                                                        title="@(Character.Level < Pf2eLookups.MinLevelForRank(val) ? $"Недоступно раньше {Pf2eLookups.MinLevelForRank(val)} уровня" : null)">@label</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="small">Class DC</span>
                                @if (_editingPf2e)
                                {
                                    <select class="form-select form-select-sm" style="width:auto;" value="@_pf2e.ClassDcRank"
                                            @onchange="e => _pf2e = _pf2e with { ClassDcRank = int.Parse(e.Value!.ToString()!) }">
                                        @foreach (var (val, label) in Pf2eRanks)
                                        {
                                            <option value="@val" disabled="@(Character.Level < Pf2eLookups.MinLevelForRank(val))"
                                                        title="@(Character.Level < Pf2eLookups.MinLevelForRank(val) ? $"Недоступно раньше {Pf2eLookups.MinLevelForRank(val)} уровня" : null)">@label</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <span class="fw-semibold" style="color:var(--ta-accent-light);">@(10 + Pf2eBonus(_pf2e.ClassDcRank))</span>
                                }
                            </div>

                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="small">Очки Героя</span>
                                @if (_editingPf2e)
                                {
                                    <div class="d-flex align-items-center gap-1">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AdjustHeroPoints(-1)">−</button>
                                        <span class="fw-semibold">@_pf2e.HeroPoints</span>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AdjustHeroPoints(1)">+</button>
                                    </div>
                                }
                                else
                                {
                                    <span class="fw-semibold" style="color:var(--ta-gold);">@_pf2e.HeroPoints</span>
                                }
                            </div>

                            <h6 class="small text-muted mt-3 mb-2">Спасброски</h6>
                            @foreach (var (key, label) in Pf2eSaves)
                            {
                                var rank = _pf2e.SaveRanks.GetValueOrDefault(key);
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <span class="small">@label</span>
                                    @if (_editingPf2e)
                                    {
                                        <select class="form-select form-select-sm" style="width:auto;" value="@rank"
                                                @onchange="e => { _pf2e.SaveRanks[key] = int.Parse(e.Value!.ToString()!); }">
                                            @foreach (var (val, rlabel) in Pf2eRanks)
                                            {
                                                <option value="@val">@rlabel</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold" style="color:var(--ta-accent-light);">+@Pf2eBonus(rank)</span>
                                    }
                                </div>
                            }

                            <h6 class="small text-muted mt-3 mb-2">Спеллкастинг</h6>
                            <div class="mb-2">
                                <label class="form-label small text-muted mb-1">Традиция</label>
                                @if (_editingPf2e)
                                {
                                    <input class="form-control form-control-sm" @bind="_pf2e.SpellcastingTradition" placeholder="напр. Arcane" />
                                }
                                else
                                {
                                    <div>@(_pf2e.SpellcastingTradition ?? "—")</div>
                                }
                            </div>
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="small">Ранг владения</span>
                                @if (_editingPf2e)
                                {
                                    <select class="form-select form-select-sm" style="width:auto;" value="@_pf2e.SpellcastingRank"
                                            @onchange="e => _pf2e = _pf2e with { SpellcastingRank = int.Parse(e.Value!.ToString()!) }">
                                        @foreach (var (val, label) in Pf2eRanks)
                                        {
                                            <option value="@val" disabled="@(Character.Level < Pf2eLookups.MinLevelForRank(val))"
                                                        title="@(Character.Level < Pf2eLookups.MinLevelForRank(val) ? $"Недоступно раньше {Pf2eLookups.MinLevelForRank(val)} уровня" : null)">@label</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <span class="fw-semibold" style="color:var(--ta-accent-light);">+@Pf2eBonus(_pf2e.SpellcastingRank)</span>
                                }
                            </div>

                            @if (_editingPf2e)
                            {
                                <div class="mt-2">
                                    <div class="small text-muted mb-1">Focus Points</div>
                                    <div class="d-flex align-items-center gap-1 mb-2">
                                        <input type="number" min="0" class="form-control form-control-sm" style="width:55px;" placeholder="исп."
                                               value="@_pf2e.FocusPoints.Used" @onchange="e => UpdateFocusPoints(_pf2e.FocusPoints with { Used = int.TryParse(e.Value?.ToString(), out var u) ? u : _pf2e.FocusPoints.Used })" />
                                        <span class="small">/</span>
                                        <input type="number" min="0" class="form-control form-control-sm" style="width:55px;" placeholder="макс."
                                               value="@_pf2e.FocusPoints.Max" @onchange="e => UpdateFocusPoints(_pf2e.FocusPoints with { Max = int.TryParse(e.Value?.ToString(), out var m) ? m : _pf2e.FocusPoints.Max })" />
                                    </div>
                                    <div class="small text-muted mb-1">Слоты по уровням</div>
                                    @foreach (var lvl in SpellSlotLevels)
                                    {
                                        var slot = SpellSlotFor(lvl);
                                        <div class="d-flex align-items-center gap-1 mb-1">
                                            <span class="small" style="width:60px;">@(lvl == 0 ? "Заговор" : $"Ур. {lvl}")</span>
                                            <input type="number" min="0" class="form-control form-control-sm" style="width:55px;" placeholder="исп."
                                                   value="@slot.Used" @onchange="e => UpdateSpellSlot(lvl, slot with { Used = int.TryParse(e.Value?.ToString(), out var u) ? u : slot.Used })" />
                                            <span class="small">/</span>
                                            <input type="number" min="0" class="form-control form-control-sm" style="width:55px;" placeholder="макс."
                                                   value="@slot.Max" @onchange="e => UpdateSpellSlot(lvl, slot with { Max = int.TryParse(e.Value?.ToString(), out var m) ? m : slot.Max })" />
                                        </div>
                                    }
                                </div>
                            }
                            else if (_pf2e.SpellSlots.Any(s => s.Value.Max > 0) || _pf2e.FocusPoints.Max > 0)
                            {
                                <div class="mt-2">
                                    @if (_pf2e.FocusPoints.Max > 0)
                                    {
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>Focus Points</span>
                                            <span class="fw-semibold" style="color:var(--ta-accent-light);">@_pf2e.FocusPoints.Used / @_pf2e.FocusPoints.Max</span>
                                        </div>
                                    }
                                    <div class="small text-muted mb-1">Слоты по уровням</div>
                                    @foreach (var lvl in SpellSlotLevels)
                                    {
                                        var slot = SpellSlotFor(lvl);
                                        @if (slot.Max > 0)
                                        {
                                            <div class="d-flex justify-content-between small mb-1">
                                                <span>@(lvl == 0 ? "Заговор" : $"Ур. {lvl}")</span>
                                                <span class="fw-semibold" style="color:var(--ta-accent-light);">@slot.Used / @slot.Max</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>

                        <div class="@ColClass">
                            <h6 class="small text-muted mb-2">Навыки</h6>
                            @foreach (var (key, label) in Pf2eSkills)
                            {
                                var rank = _pf2e.SkillRanks.GetValueOrDefault(key);
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <span class="small">@label</span>
                                    @if (_editingPf2e)
                                    {
                                        <select class="form-select form-select-sm" style="width:auto;" value="@rank"
                                                @onchange="e => { _pf2e.SkillRanks[key] = int.Parse(e.Value!.ToString()!); }">
                                            @foreach (var (val, rlabel) in Pf2eRanks)
                                            {
                                                <option value="@val">@rlabel</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        var featBonus = _skillBonusFromFeats.GetValueOrDefault(key);
                                        <span class="fw-semibold" style="color:var(--ta-accent-light);">
                                            +@(Pf2eBonus(rank) + featBonus)
                                            @if (featBonus != 0)
                                            {
                                                <small class="text-success" title="Автоматически из связанных фитов (J.1)">(@Pf2eBonus(rank)+@featBonus)</small>
                                            }
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0">Инвентарь</h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddInventoryItem">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.Inventory.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.Inventory.Count; i++)
                                {
                                    var idx = i;
                                    var item = _pf2e.Inventory[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex gap-1 align-items-center mb-1">
                                            <input class="form-control form-control-sm" placeholder="Название" value="@item.Name"
                                                   @onchange='e => UpdateInventoryItem(idx, item with { Name = e.Value?.ToString() ?? "" })' />
                                            <input type="number" min="0" class="form-control form-control-sm" style="width:56px;" value="@item.Quantity"
                                                   @onchange="e => UpdateInventoryItem(idx, item with { Quantity = int.TryParse(e.Value?.ToString(), out var q) ? q : item.Quantity })" />
                                            <input type="number" min="0" step="0.1" class="form-control form-control-sm" style="width:64px;" value="@item.Bulk"
                                                   @onchange="e => UpdateInventoryItem(idx, item with { Bulk = double.TryParse(e.Value?.ToString(), out var b) ? b : item.Bulk })" />
                                            <input type="checkbox" class="form-check-input" checked="@item.Equipped" title="Экипировано"
                                                   @onchange="e => UpdateInventoryItem(idx, item with { Equipped = (bool)(e.Value ?? false) })" />
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveInventoryItem(idx)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>@(item.Equipped ? "⚔ " : "")@item.Name ×@item.Quantity</span>
                                            <span class="text-muted">@item.Bulk</span>
                                        </div>
                                    }
                                }
                            }
                        </div>

                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0">Атаки</h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddAttack">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.Attacks.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.Attacks.Count; i++)
                                {
                                    var idx = i;
                                    var atk = _pf2e.Attacks[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex flex-column gap-1 mb-2 pb-2" style="border-bottom:1px solid var(--ta-border);">
                                            <div class="d-flex gap-1">
                                                <input class="form-control form-control-sm" placeholder="Название" value="@atk.Name"
                                                       @onchange='e => UpdateAttack(idx, atk with { Name = e.Value?.ToString() ?? "" })' />
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAttack(idx)">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <select class="form-select form-select-sm" value="@atk.Rank"
                                                        @onchange="e => UpdateAttack(idx, atk with { Rank = int.Parse(e.Value!.ToString()!) })">
                                                    @foreach (var (val, label) in Pf2eRanks)
                                                    {
                                                        <option value="@val" disabled="@(Character.Level < Pf2eLookups.MinLevelForRank(val))"
                                                        title="@(Character.Level < Pf2eLookups.MinLevelForRank(val) ? $"Недоступно раньше {Pf2eLookups.MinLevelForRank(val)} уровня" : null)">@label</option>
                                                    }
                                                </select>
                                                <select class="form-select form-select-sm" value="@atk.AbilityKey"
                                                        @onchange='e => UpdateAttack(idx, atk with { AbilityKey = e.Value?.ToString() ?? "str" })'>
                                                    @foreach (var (key, label) in Pf2eAbilities)
                                                    {
                                                        <option value="@key">@label</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <input class="form-control form-control-sm" placeholder="кость, напр. 1d6" style="width:80px;" value="@atk.DamageDice"
                                                       @onchange='e => UpdateAttack(idx, atk with { DamageDice = e.Value?.ToString() ?? "1d4" })' />
                                                <input type="number" class="form-control form-control-sm" placeholder="бонус" style="width:60px;" value="@atk.DamageBonus"
                                                       @onchange="e => UpdateAttack(idx, atk with { DamageBonus = int.TryParse(e.Value?.ToString(), out var b) ? b : atk.DamageBonus })" />
                                                <input class="form-control form-control-sm" placeholder="тип урона" value="@atk.DamageType"
                                                       @onchange='e => UpdateAttack(idx, atk with { DamageType = e.Value?.ToString() })' />
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>@atk.Name</span>
                                            <span class="text-muted">
                                                +@(Pf2eBonus(atk.Rank) + AbilityModByKey(atk.AbilityKey)) · @atk.DamageDice@(atk.DamageBonus != 0 ? (atk.DamageBonus > 0 ? $"+{atk.DamageBonus}" : $"{atk.DamageBonus}") : "")
                                            </span>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>

                    <div class="row g-4 mt-1">
                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0">Ресурсы класса</h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddResource">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.Resources.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто (напр. Focus Points, Ki)</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.Resources.Count; i++)
                                {
                                    var idx = i;
                                    var res = _pf2e.Resources[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex gap-1 align-items-center mb-1">
                                            <input class="form-control form-control-sm" placeholder="Название" value="@res.Name"
                                                   @onchange='e => UpdateResource(idx, res with { Name = e.Value?.ToString() ?? "" })' />
                                            <input type="number" min="0" class="form-control form-control-sm" style="width:55px;" value="@res.Current"
                                                   @onchange="e => UpdateResource(idx, res with { Current = int.TryParse(e.Value?.ToString(), out var c) ? c : res.Current })" />
                                            <span class="small">/</span>
                                            <input type="number" min="0" class="form-control form-control-sm" style="width:55px;" value="@res.Max"
                                                   @onchange="e => UpdateResource(idx, res with { Max = int.TryParse(e.Value?.ToString(), out var m) ? m : res.Max })" />
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveResource(idx)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>@res.Name</span>
                                            <span class="fw-semibold" style="color:var(--ta-accent-light);">@res.Current / @res.Max</span>
                                        </div>
                                    }
                                }
                            }
                        </div>

                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0" title="Ручные roll options для предикатов, которые не покрыты автоматикой (например, target:mark:hunted-prey у фитов Hunt Prey) — вписывается та же строка, что фит ожидает в своём predicate">
                                    Свои roll options
                                </h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddCustomRollOption">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.CustomRollOptions.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто (напр. target:mark:hunted-prey)</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.CustomRollOptions.Count; i++)
                                {
                                    var idx = i;
                                    var opt = _pf2e.CustomRollOptions[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex gap-1 align-items-center mb-1">
                                            <input class="form-control form-control-sm" placeholder="напр. target:mark:hunted-prey" value="@opt"
                                                   @onchange="e => UpdateCustomRollOption(idx, e.Value?.ToString() ?? string.Empty)" />
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCustomRollOption(idx)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="small mb-1"><code>@opt</code></div>
                                    }
                                }
                            }
                        </div>

                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0">Фиты</h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddFeat">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.Feats.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.Feats.Count; i++)
                                {
                                    var idx = i;
                                    var feat = _pf2e.Feats[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex gap-1 align-items-center mb-1">
                                            <input class="form-control form-control-sm" placeholder="Название фита (точное — свяжется со справочником)" value="@feat.Name"
                                                   @onchange='e => UpdateFeat(idx, feat with { Name = e.Value?.ToString() ?? "" })' />
                                            <input type="number" min="1" max="20" class="form-control form-control-sm" style="width:55px;" placeholder="ур." value="@feat.Level"
                                                   @onchange="e => UpdateFeat(idx, feat with { Level = int.TryParse(e.Value?.ToString(), out var l) ? l : feat.Level })" />
                                            <select class="form-select form-select-sm" style="width:auto;" value="@feat.Source" title="Из какого слота взят этот фит"
                                                    @onchange="e => UpdateFeat(idx, feat with { Source = string.IsNullOrWhiteSpace(e.Value?.ToString()) ? null : e.Value.ToString() })">
                                                <option value="">Слот —</option>
                                                @foreach (var (key, label) in Pf2eLookups.FeatSources)
                                                {
                                                    <option value="@key">@label</option>
                                                }
                                            </select>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFeat(idx)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between align-items-center small mb-1">
                                            <span>
                                                @feat.Name
                                                @if (feat.Slug is not null)
                                                {
                                                    <i class="bi bi-link-45deg text-success" title="Связан со справочником — правила применяются автоматически"></i>
                                                }
                                                @if (feat.Source is not null)
                                                {
                                                    <span class="badge bg-secondary ms-1" style="font-size:.65rem;">@Pf2eLookups.FeatSources.First(s => s.Key == feat.Source).Label</span>
                                                }
                                            </span>
                                            <span class="text-muted">ур. @feat.Level</span>
                                        </div>
                                        @if (feat.Slug is not null && _grantsByFeatSlug.TryGetValue(feat.Slug, out var grants))
                                        {
                                            <div class="small text-muted fst-italic mb-1" style="margin-top:-4px;">Даёт: @string.Join(", ", grants)</div>
                                        }
                                        @if (feat.Slug is not null && _choiceSetByFeatSlug.TryGetValue(feat.Slug, out var choiceSet))
                                        {
                                            <div class="d-flex align-items-center gap-2 mb-1" style="margin-top:-4px;">
                                                <span class="small text-muted">@choiceSet.Prompt:</span>
                                                <select class="form-select form-select-sm" style="width:auto;" value="@feat.SelectedChoice"
                                                        @onchange="e => SetFeatChoiceAsync(idx, e.Value?.ToString())">
                                                    <option value="">—</option>
                                                    @foreach (var opt in choiceSet.Options)
                                                    {
                                                        <option value="@opt.Value">@opt.Label</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                        @if (feat.Slug is not null && _rollOptionsByFeatSlug.TryGetValue(feat.Slug, out var featToggles))
                                        {
                                            @foreach (var toggle in featToggles)
                                            {
                                                var isOn = feat.ToggledOptions?.Contains(toggle.Option) ?? toggle.Default;
                                                <div class="form-check form-switch mb-1" style="margin-top:-4px;">
                                                    <input class="form-check-input" type="checkbox" checked="@isOn"
                                                           @onchange="e => ToggleFeatRollOptionAsync(idx, toggle.Option, (bool)(e.Value ?? false))" />
                                                    <label class="form-check-label small text-muted">@toggle.Label</label>
                                                </div>
                                            }
                                        }
                                    }
                                }
                            }
                        </div>

                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0">Известные заклинания</h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddKnownSpell">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.KnownSpells.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.KnownSpells.Count; i++)
                                {
                                    var idx = i;
                                    var spell = _pf2e.KnownSpells[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex gap-1 align-items-center mb-1">
                                            <input class="form-control form-control-sm" placeholder="Название" value="@spell.Name"
                                                   @onchange='e => UpdateKnownSpell(idx, spell with { Name = e.Value?.ToString() ?? "" })' />
                                            <input type="number" min="0" max="10" class="form-control form-control-sm" style="width:50px;" placeholder="ур." value="@spell.Level"
                                                   @onchange="e => UpdateKnownSpell(idx, spell with { Level = int.TryParse(e.Value?.ToString(), out var l) ? l : spell.Level })" />
                                            <input type="checkbox" class="form-check-input" checked="@spell.Prepared" title="Подготовлено"
                                                   @onchange="e => UpdateKnownSpell(idx, spell with { Prepared = (bool)(e.Value ?? false) })" />
                                            <input type="checkbox" class="form-check-input" checked="@spell.IsFocus" title="Фокус-заклинание (тратит Focus Point, не слот)"
                                                   @onchange="e => UpdateKnownSpell(idx, spell with { IsFocus = (bool)(e.Value ?? false) })" />
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveKnownSpell(idx)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>@(spell.Prepared ? "✓ " : "")@spell.Name @(spell.IsFocus ? " 🔷" : "")</span>
                                            <span class="text-muted">ур. @spell.Level</span>
                                        </div>
                                    }
                                }
                            }
                        </div>
                        <div class="@ColClass">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="small text-muted mb-0">Известные формулы (крафт)</h6>
                                @if (_editingPf2e)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddKnownFormula">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            @if (_pf2e.KnownFormulas.Count == 0)
                            {
                                <p class="small text-muted fst-italic mb-0">Пусто</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _pf2e.KnownFormulas.Count; i++)
                                {
                                    var idx = i;
                                    var formula = _pf2e.KnownFormulas[idx];
                                    @if (_editingPf2e)
                                    {
                                        <div class="d-flex gap-1 align-items-center mb-1">
                                            <input class="form-control form-control-sm" placeholder="Название предмета (точное — свяжется со справочником)" value="@formula.Name"
                                                   @onchange='e => UpdateKnownFormula(idx, formula with { Name = e.Value?.ToString() ?? "" })' />
                                            <input type="number" min="0" max="25" class="form-control form-control-sm" style="width:55px;" placeholder="ур." value="@formula.Level"
                                                   @onchange="e => UpdateKnownFormula(idx, formula with { Level = int.TryParse(e.Value?.ToString(), out var l) ? l : formula.Level })" />
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveKnownFormula(idx)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between align-items-center small mb-1">
                                            <span>
                                                @formula.Name
                                                @if (formula.Slug is not null)
                                                {
                                                    <i class="bi bi-link-45deg text-success" title="Связан со справочником"></i>
                                                }
                                            </span>
                                            <span class="d-flex align-items-center gap-2">
                                                <span class="text-muted">ур. @formula.Level, DC @Pf2eLookups.StandardDc(formula.Level)</span>
                                                <button class="btn btn-sm btn-outline-warning py-0 px-1" title="Скрафтить (бросок Ремесла)"
                                                        @onclick="() => CraftFormula(formula)">
                                                    <i class="bi bi-hammer"></i>
                                                </button>
                                            </span>
                                        </div>
                                    }
                                }
                                @if (_craftResultMessage is not null)
                                {
                                    <p class="small fst-italic mt-2 mb-0" style="color:var(--ta-gold);">@_craftResultMessage</p>
                                }
                            }
                        </div>
                    </div>
    </div>
}
