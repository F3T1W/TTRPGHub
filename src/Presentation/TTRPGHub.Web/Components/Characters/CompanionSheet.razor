@using TTRPGHub.Services

<div class="ta-card p-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="mb-0" style="font-family:'Cinzel',serif;">Компаньоны и фамильяры</h5>
        @if (!_adding)
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="StartAdd">
                <i class="bi bi-plus-lg me-1"></i>Добавить
            </button>
        }
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger py-2 small">@_error</div>
    }

    @if (_adding)
    {
        <div class="border rounded p-3 mb-3" style="border-color:var(--ta-border)!important;">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="small text-muted">Имя</label>
                    <input class="form-control form-control-sm" @bind="_name" placeholder="Имя компаньона" />
                </div>
                <div class="col-md-4">
                    <label class="small text-muted">Тип</label>
                    <input class="form-control form-control-sm" @bind="_kind" placeholder="Компаньон / Фамильяр" />
                </div>
                <div class="col-md-2">
                    <label class="small text-muted">Уровень</label>
                    <input type="number" min="1" max="20" class="form-control form-control-sm" @bind="_level" />
                </div>
                <div class="col-md-2">
                    <label class="small text-muted">КБ</label>
                    <input type="number" class="form-control form-control-sm" @bind="_ac" />
                </div>
                <div class="col-md-3">
                    <label class="small text-muted">Макс. ХП</label>
                    <input type="number" min="0" class="form-control form-control-sm" @bind="_maxHp" />
                </div>
                @if (_editingId is not null)
                {
                    <div class="col-md-3">
                        <label class="small text-muted">Текущие ХП</label>
                        <input type="number" min="0" class="form-control form-control-sm" @bind="_currentHp" />
                    </div>
                }
                <div class="col-md-3">
                    <label class="small text-muted">Скорость</label>
                    <input class="form-control form-control-sm" @bind="_speed" placeholder="25 фт" />
                </div>
                <div class="col-12">
                    <label class="small text-muted">Атаки</label>
                    <input class="form-control form-control-sm" @bind="_attacksText" placeholder="Укус +8, 1d6+4 колющий" />
                </div>
                <div class="col-12">
                    <label class="small text-muted">Способности</label>
                    <textarea class="form-control form-control-sm" rows="2" @bind="_abilitiesText"></textarea>
                </div>
                <div class="col-12">
                    <label class="small text-muted">Заметки</label>
                    <textarea class="form-control form-control-sm" rows="2" @bind="_notes"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-sm btn-success" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Сохранить
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelAdd">Отмена</button>
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center py-3"><div class="spinner-border spinner-border-sm" style="color:var(--ta-accent);"></div></div>
    }
    else if (_companions.Count == 0)
    {
        <p class="small text-muted fst-italic mb-0">Пока нет компаньонов</p>
    }
    else
    {
        <div class="row g-2">
            @foreach (var c in _companions)
            {
                <div class="col-md-6">
                    <div class="p-2" style="background:var(--ta-bg); border-radius:6px;">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="fw-semibold text-white">@c.Name</span>
                                <span class="text-muted small"> · @c.Kind · ур. @c.Level</span>
                            </div>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="() => StartEdit(c)" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => DeleteAsync(c.Id)" title="Удалить">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 small mt-1">
                            <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="() => AdjustHpAsync(c, -1)">−</button>
                            <span style="color:var(--ta-gold);">@c.CurrentHitPoints / @c.MaxHitPoints ХП</span>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="() => AdjustHpAsync(c, 1)">+</button>
                            @if (c.ArmorClass is { } ac)
                            {
                                <span class="text-muted">· КБ @ac</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(c.Speed))
                            {
                                <span class="text-muted">· @c.Speed</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(c.AttacksText))
                        {
                            <div class="small text-muted mt-1">Атаки: @c.AttacksText</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.AbilitiesText))
                        {
                            <div class="small text-muted">Способности: @c.AbilitiesText</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
