@inherits LayoutComponentBase
@inject AppAuthStateProvider AuthProvider
@inject NavigationManager Nav

<div class="d-flex flex-column" style="min-height:100vh;">

    <!-- Navbar -->
    <nav class="navbar ta-navbar px-3 py-0" style="height:56px; position:sticky; top:0; z-index:100;">
        <a class="navbar-brand ta-navbar-brand" href="/">
            <i class="bi bi-shield-fill-exclamation me-2"></i>Таверна Аферистов
        </a>

        <div class="ms-auto d-flex align-items-center gap-2">
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted small d-none d-md-inline">
                        <i class="bi bi-person-circle me-1"></i>@context.User.FindFirst("unique_name")?.Value
                    </span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="LogoutAsync">
                        <i class="bi bi-box-arrow-right me-1"></i>Выйти
                    </button>
                </Authorized>
                <NotAuthorized>
                    <a href="/login"    class="btn btn-sm btn-outline-secondary">Войти</a>
                    <a href="/register" class="btn btn-sm btn-ta-primary ms-1">Регистрация</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <!-- Тело -->
    <div class="d-flex flex-grow-1">
        <AuthorizeView>
            <Authorized>
                <aside class="ta-sidebar d-none d-lg-flex flex-column p-3">
                    <NavMenu />
                </aside>
            </Authorized>
        </AuthorizeView>

        <main class="flex-grow-1 p-4" style="min-width:0; overflow-x:hidden;">
            @Body
        </main>
    </div>
</div>

@code {
    private async Task LogoutAsync()
    {
        await AuthProvider.NotifyLogoutAsync();
        Nav.NavigateTo("/login");
    }
}
